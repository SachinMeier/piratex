{
  "name": "piratex-tui",
  "version": "0.1.0",
  "description": "Terminal client for Piratex (Pirate Scrabble)",
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "build": "bun build --compile src/index.tsx --outfile ../../bin/piratex",
    "dev": "bun --watch src/index.tsx",
    "start": "bun src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "phoenix": "^1.7.14",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/phoenix": "^1.6.7",
    "@types/react": "^18.3.3",
    "@types/ws": "^8.5.12",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
